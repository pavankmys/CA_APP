# Copy this file to .streamlit/secrets.toml (and fill in your real connection
# string) for local testing, or paste its contents into the "Secrets" section
# of your Streamlit Community Cloud app settings.
#
# Get the URI from: Supabase project -> Connect -> Connection string -> URI
# Format: postgresql://postgres:[YOUR-PASSWORD]@[HOST]:[PORT]/postgres

SUPABASE_DB_URL = "postgresql://postgres:[YOUR-PASSWORD]@[HOST]:[PORT]/postgres"

# Optional: protect the hosted app with a shared password. If unset, the app
# is open to anyone with the URL. Choose your own value.
APP_PASSWORD = "change-me"
