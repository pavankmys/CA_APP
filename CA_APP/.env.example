# =======================================================
# CA Inter Practice App - Configuration
# Copy this file to .env and fill in your API keys.
# Set AI_PROVIDER to: 'gemini', 'claude', 'grok', or 'kimchi'
# =======================================================

AI_PROVIDER=gemini

# --- Google Gemini (gemini-2.5-flash) ---
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Anthropic Claude (claude-haiku-4-5) ---
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- xAI Grok (grok-3-mini) ---
# Get key from: https://console.x.ai
XAI_API_KEY=

# --- Kimchi / CAST AI (kimi-k2.5) ---
# Get key from: https://www.kimchi.dev  |  $50 free credits, no card required
KIMCHI_API_KEY=

# --- Supabase Postgres connection (used by database.py) ---
# Get the URI from: Supabase project -> Connect -> Connection string -> URI
# Format: postgresql://postgres:[YOUR-PASSWORD]@[HOST]:[PORT]/postgres
SUPABASE_DB_URL=

# --- Cloudflare R2 (used by audio_publish.py for the Audio Notes podcast feed) ---
# R2 dashboard: Cloudflare dashboard -> R2 Object Storage -> Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket name (create it in the R2 dashboard, enable "Public Development URL" or a
# custom domain so files are readable by podcast apps)
R2_BUCKET=
# Public base URL for the bucket, e.g. https://pub-xxxxxxxx.r2.dev or your custom domain
R2_PUBLIC_URL=

# Podcast feed URL (= R2_PUBLIC_URL + /feed.xml) — add this in your podcast app via
# "Add by URL" / "Follow a Show by URL"
PODCAST_FEED_URL=

# --- Optional password gate for app.py (leave blank to disable) ---
APP_PASSWORD=
